# Copy to .env and fill in. Never commit the real .env.

# --- Lightspeed API ---
# Clients are environment-bound: a trial client only works on trial, prod on prod.
# V2 client id begins with devp-v2-prod-... (production) or devp-v2-demo-... (trial).

# API host (data endpoints):
#   Production: https://api.lsk.lightspeed.app
#   Trial:      https://api.trial.lsk.lightspeed.app
LS_API_BASE=https://api.lsk.lightspeed.app

# OAuth host (SEPARATE from the API host -- Keycloak realm 'k-series'):
#   Production: https://auth.lsk-prod.app/...
#   Trial:      https://auth.lsk-demo.app/...
LS_AUTHORIZE_URL=https://auth.lsk-prod.app/realms/k-series/protocol/openid-connect/auth
LS_TOKEN_URL=https://auth.lsk-prod.app/realms/k-series/protocol/openid-connect/token

LS_CLIENT_ID=
LS_CLIENT_SECRET=
LS_SCOPES=financial-api items offline_access
LS_REDIRECT_URI=https://localhost/

# Initial seed only. After the first refresh the live (rotating) token is stored
# in the oauth_token table; you don't normally need to set this once get_refresh_token
# has run and saved it to the DB.
LS_REFRESH_TOKEN=

# Endpoint paths (confirmed against the API reference 2026-06-03)
LS_PATH_BUSINESSES=/f/data/businesses
LS_PATH_SALES=/f/v2/business-location/{blid}/sales
LS_PATH_ITEMS=/items/v1/items

# --- Database ---
# Local: a local Postgres. Production (Railway): your Neon connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lightspeed

# --- Google Sheets (cash-off forms) ---
# Locally the importer reads gcp-cashoff-key.json from disk (gitignored).
# On a server with no file, paste the WHOLE service-account JSON here instead:
# GCP_KEY_JSON={"type":"service_account",...}

# --- Ingestion tuning ---
LS_BACKFILL_DAYS=365
LS_OVERLAP_HOURS=48
